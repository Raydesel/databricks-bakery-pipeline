{
  "datasets": [
    {
      "name": "revenue_summary",
      "displayName": "Revenue Summary Metrics",
      "queryLines": [
        "SELECT\n",
        "  SUM(totalPrice) as total_revenue,\n",
        "  AVG(totalPrice) as avg_order_value,\n",
        "  COUNT(*) as transaction_count,\n",
        "  AVG(quantity) as avg_items_per_transaction\n",
        "FROM\n",
        "  workspace.raydesel_bakery_project.bronze_sales_transactions"
      ],
      "catalog": "workspace",
      "schema": "raydesel_bakery_project"
    },
    {
      "name": "revenue_by_city",
      "displayName": "Revenue by City",
      "queryLines": [
        "SELECT\n",
        "  f.city,\n",
        "  SUM(t.totalPrice) as total_revenue\n",
        "FROM\n",
        "  bronze_sales_transactions t\n",
        "    JOIN bronze_sales_franchises f\n",
        "      ON t.franchiseID = f.franchiseID\n",
        "GROUP BY\n",
        "  f.city\n",
        "ORDER BY\n",
        "  total_revenue DESC"
      ],
      "catalog": "workspace",
      "schema": "raydesel_bakery_project"
    },
    {
      "name": "top_products",
      "displayName": "Top Products by Revenue",
      "queryLines": [
        "SELECT\n",
        "  product,\n",
        "  SUM(totalPrice) as total_revenue,\n",
        "  SUM(quantity) as total_quantity\n",
        "FROM\n",
        "  bronze_sales_transactions\n",
        "GROUP BY\n",
        "  product\n",
        "ORDER BY\n",
        "  total_revenue DESC"
      ],
      "catalog": "workspace",
      "schema": "raydesel_bakery_project"
    },
    {
      "name": "daily_sales",
      "displayName": "Daily Sales Trend",
      "queryLines": [
        "SELECT\n",
        "  DATE(dateTime) as sale_date,\n",
        "  SUM(totalPrice) as daily_revenue,\n",
        "  COUNT(*) as daily_transactions\n",
        "FROM\n",
        "  bronze_sales_transactions\n",
        "GROUP BY\n",
        "  DATE(dateTime)\n",
        "ORDER BY\n",
        "  sale_date"
      ],
      "catalog": "workspace",
      "schema": "raydesel_bakery_project"
    },
    {
      "name": "sales_by_hour",
      "displayName": "Sales by Hour",
      "queryLines": [
        "SELECT\n",
        "  HOUR(dateTime) as hour_of_day,\n",
        "  SUM(totalPrice) as hourly_revenue,\n",
        "  COUNT(*) as hourly_transactions\n",
        "FROM\n",
        "  bronze_sales_transactions\n",
        "GROUP BY\n",
        "  HOUR(dateTime)\n",
        "ORDER BY\n",
        "  hour_of_day"
      ],
      "catalog": "workspace",
      "schema": "raydesel_bakery_project"
    },
    {
      "name": "payment_methods",
      "displayName": "Payment Method Distribution",
      "queryLines": [
        "SELECT\n",
        "  paymentMethod,\n",
        "  COUNT(*) as transaction_count,\n",
        "  SUM(totalPrice) as total_revenue\n",
        "FROM\n",
        "  bronze_sales_transactions\n",
        "GROUP BY\n",
        "  paymentMethod\n",
        "ORDER BY\n",
        "  transaction_count DESC"
      ],
      "catalog": "workspace",
      "schema": "raydesel_bakery_project"
    },
    {
      "name": "revenue_by_store",
      "displayName": "Revenue by Store",
      "queryLines": [
        "SELECT\n",
        "  f.franchiseID,\n",
        "  f.name as store_name,\n",
        "  f.city,\n",
        "  SUM(t.totalPrice) as total_revenue,\n",
        "  COUNT(*) as transaction_count\n",
        "FROM\n",
        "  bronze_sales_transactions t\n",
        "    JOIN bronze_sales_franchises f\n",
        "      ON t.franchiseID = f.franchiseID\n",
        "GROUP BY\n",
        "  f.franchiseID,\n",
        "  f.name,\n",
        "  f.city\n",
        "ORDER BY\n",
        "  total_revenue DESC"
      ],
      "catalog": "workspace",
      "schema": "raydesel_bakery_project"
    }
  ],
